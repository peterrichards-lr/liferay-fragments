          "name": "backgroundImage",
          "type": "itemSelector",
          "typeOptions": {
            "itemType": "com.liferay.portal.kernel.repository.model.FileEntry",
            "mimeTypes": [
              "image/png",
              "image/webp",
              "image/jpeg",
              "image/gif",
              "image/apng",
              "image/avif"
            ]
          }
        },
        {
          "label": "lfr.hero-assets.background-image-alt",
          "description": "lfr.hero-assets.background-image-alt-description",
          "name": "backgroundImageAlt",
          "type": "text"
        },
        {
          "label": "lfr.hero-assets.aria-label",
          "description": "lfr.hero-assets.aria-label-description",
          "name": "ariaLabel",
          "type": "text"
        },
        {
          "dataType": "int",
          "defaultValue": "50",
          "label": "lfr.hero-assets.focal-x",
          "description": "lfr.hero-assets.focal-x-description",
          "name": "focalX",
          "type": "text",
          "typeOptions": {
            "validation": {
              "max": 100,
              "min": 0,
              "type": "number"
            }
          }
        },
        {
          "dataType": "int",
          "defaultValue": "50",
          "label": "lfr.hero-assets.focal-y",
          "description": "lfr.hero-assets.focal-y-description",
          "name": "focalY",
          "type": "text",
          "typeOptions": {
            "validation": {
              "max": 100,
              "min": 0,
              "type": "number"
            }
          }
        }
      ],
      "label": "lfr.hero-assets.image"
    },
    {
      "configurationRole": "style",
      "fields": [
        {
          "defaultValue": "#000000",
          "label": "lfr.hero-assets.overlay-color",
          "description": "lfr.hero-assets.overlay-color-description",
          "name": "overlayColor",
          "type": "colorPicker"
        },
        {
          "dataType": "int",
          "defaultValue": "40",
          "label": "lfr.hero-assets.alpha",
          "description": "lfr.hero-assets.alpha-description",
          "name": "alpha",
          "type": "text",
          "typeOptions": {
            "validation": {
              "max": 100,
              "min": 0,
              "type": "number"
            }
          }
        }
      ],
      "label": "lfr.hero-assets.overlay"
    },
    {
      "configurationRole": "advanced",
      "fields": [
        {
          "defaultValue": false,
          "label": "lfr.hero-assets.enable-debug",
          "description": "lfr.hero-assets.enable-debug-description",
          "name": "enableDebug",
          "type": "checkbox"
        }
      ],
      "label": "lfr.hero-assets.miscellaneous"
    }
  ]
