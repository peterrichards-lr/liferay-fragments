{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Liferay Fragment Collection Schema",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the fragment collection"
    },
    "description": {
      "type": "string",
      "description": "A description of the fragment collection"
    }
  },
  "additionalProperties": false
}
