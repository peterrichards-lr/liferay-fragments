{
  "name": "liferay-fragments",
  "version": "6.3.4",
  "description": "High-fidelity Liferay DXP Fragments",
  "main": "index.js",
  "scripts": {
    "lint": "node scripts/lint-fragments.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "create-fragment": "node scripts/create-fragment.js",
    "docs:gallery": "node scripts/generate-gallery.js",
    "test:visual": "node scripts/verify-snapshots.js",
