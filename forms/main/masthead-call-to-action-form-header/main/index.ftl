<section class="masthead masthead-form text-white d-flex py-5" style="
  background-image: linear-gradient(rgba(0,0,0,${configuration.overlayOpacity!"0.5"}), rgba(0,0,0,${configuration.overlayOpacity!"0.5"})), url('${(configuration.backgroundImage.url)!"https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=1920"}');
  background-size: cover;
  background-position: center;
  min-height: 500px;
  align-items: center;
">
  <div class="container py-4">
    <div class="row align-items-center">
      <div class="col-lg-7 mb-4 mb-lg-0 text-left">
        <h1 class="display-4 font-weight-bold mb-3" data-lfr-editable-id="title" data-lfr-editable-type="rich-text">
          Join Our Global Community
        </h1>
        <p class="lead mb-4 text-white-50" data-lfr-editable-id="description" data-lfr-editable-type="rich-text">
          Sign up to receive the latest updates, exclusive resources, and deep insights from our experts.
        </p>
      </div>
      <div class="col-lg-5">
        <div class="card bg-dark text-white border-0 shadow-lg" style="background: rgba(15, 23, 42, 0.85) !important; backdrop-filter: blur(10px);">
          <div class="card-body p-4">
            <h4 class="card-title mb-3 font-weight-semibold" data-lfr-editable-id="form-title" data-lfr-editable-type="text">
              Request Information
            </h4>
            <div class="row text-left">
              <lfr-drop-zone></lfr-drop-zone>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
