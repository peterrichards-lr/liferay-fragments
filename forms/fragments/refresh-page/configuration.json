{
  "fieldSets": [
    {
      "fields": [
        {
          "defaultValue": true,
          "label": "lfr.forms.enable-auto-refresh",
          "description": "lfr.forms.enable-auto-refresh-description",
          "name": "enableAutoRefresh",
          "type": "checkbox"
        },
        {
          "defaultValue": "5",
          "label": "lfr.forms.refresh-interval-seconds",
          "description": "lfr.forms.refresh-interval-seconds-description",
          "name": "refreshIntervalSec",
          "type": "text",
          "dataType": "int",
          "typeOptions": {
            "dependency": {
              "enableAutoRefresh": {
                "type": "equal",
                "value": "true"
              }
            }
          }
        },
        {
          "defaultValue": true,
          "label": "lfr.forms.enable-manual-refresh",
          "description": "lfr.forms.enable-manual-refresh-description",
          "name": "enableManualRefresh",
          "type": "checkbox"
        },
        {
          "defaultValue": "click here",
          "label": "lfr.forms.refresh-link-text",
          "description": "lfr.forms.refresh-link-text-description",
          "name": "manualRefreshText",
          "type": "text",
          "typeOptions": {
            "dependency": {
              "enableManualRefresh": {
                "type": "equal",
                "value": "true"
              }
            }
          }
        },
        {
          "defaultValue": ".lfr-message-success",
          "label": "lfr.forms.refresh-condition-element",
          "description": "lfr.forms.refresh-condition-element-description",
          "name": "conditionElement",
          "type": "text"
        }
      ],
      "label": "lfr.forms.behaviour"
    }
  ]
}
